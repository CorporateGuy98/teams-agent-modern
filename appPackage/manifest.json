{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.19/MicrosoftTeams.schema.json",
  "manifestVersion": "1.19",
  "version": "1.0.0",
  "id": "${{TEAMS_APP_ID}}",
  "developer": {
    "name": "Klimasan IT",
    "websiteUrl": "https://www.klimasan.com.tr",
    "privacyUrl": "https://www.klimasan.com.tr/privacy",
    "termsOfUseUrl": "https://www.klimasan.com.tr/terms"
  },
  "name": {
    "short": "IT Yardım Masası",
    "full": "IT Yardım Masası Botu"
  },
  "description": {
    "short": "IT destek talebi oluşturun",
    "full": "Yaşadığınız teknik sorunu yazın, otomatik olarak destek bileti oluşturulsun."
  },
  "icons": {
    "outline": "outline.png",
    "color": "color.png"
  },
  "accentColor": "#0078D4",
  "bots": [
    {
      "botId": "${{BOT_ID}}",
      "scopes": ["personal", "team", "groupChat"],
      "supportsFiles": true,
      "isNotificationOnly": false,
      "commandLists": [
        {
          "scopes": ["personal"],
          "commands": [
            {
              "title": "yardım",
              "description": "Bot hakkında bilgi alın"
            }
          ]
        }
      ]
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": []
}
